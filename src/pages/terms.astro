---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Terms of Use — Echo 7"
  description="Echo 7 terms of use. Solvida Ltd trading as Echo 7, registered in England and Wales."
  canonicalPath="/terms/"
>
  <Nav />
  <main>
    <section class="section">
      <div class="container text-column legal">
        <p class="legal__draft-notice">
          Draft — pending legal review before this page is considered final.
        </p>
        <h1>Terms of Use</h1>
        <p class="legal__updated">Last updated: 22 June 2026</p>

        <p>
          Echo 7 is a trading name of Solvida Ltd, a company registered in England and
          Wales. These terms govern your use of this website.
        </p>

        <h2>Use of this site</h2>
        <p>
          This website is provided for general information about Echo 7's services. You
          may browse it freely. The content, design, and underlying code of this site are
          the property of Solvida Ltd and may not be copied or reproduced without
          permission.
        </p>

        <h2>No advice given here</h2>
        <p>
          Nothing on this website constitutes a binding quote, technical assessment, or
          professional advice. Figures presented for illustration — including example cost
          models — are illustrative only and do not represent a guarantee for any specific
          business. Specific findings and pricing are only provided following a direct
          engagement.
        </p>

        <h2>Enquiries and engagements</h2>
        <p>
          Submitting the contact form does not create a contract between you and Solvida
          Ltd. Any engagement, including the scope and fee for a Sovereignty Index™
          diagnostic, is agreed separately and in writing before work begins.
        </p>

        <h2>Liability</h2>
        <p>
          This website is provided "as is" without warranties of any kind. Solvida Ltd is
          not liable for any loss arising from reliance on general information published
          on this site.
        </p>

        <h2>Contact</h2>
        <p>
          Questions about these terms can be sent to
          <a href="mailto:hello@echo7.io">hello@echo7.io</a>.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal {
    padding-block: var(--space-md);
  }

  .legal__draft-notice {
    display: inline-block;
    margin-bottom: var(--space-md);
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--colour-accent);
    border-radius: var(--radius-sm);
    color: var(--colour-accent);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
  }

  .legal h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
  }

  .legal__updated {
    margin-top: var(--space-sm);
    color: var(--colour-text-muted);
    font-size: 0.85rem;
  }

  .legal h2 {
    margin-top: var(--space-lg);
    font-size: 1.3rem;
    color: var(--colour-accent);
  }

  .legal p {
    margin-top: var(--space-sm);
    color: var(--colour-text-muted);
    line-height: 1.7;
  }

  .legal a {
    color: var(--colour-accent);
  }
</style>
