---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Thank You — Echo 7"
  description="Your message has reached Echo 7. We review every submission and respond within one working day."
  canonicalPath="/contact/thank-you"
>
  <Nav />
  <main>
    <section class="section thankyou">
      <div class="container text-column">
        <p class="thankyou__eyebrow">Message sent</p>
        <h1 class="thankyou__headline">Thank you.</h1>
        <p class="thankyou__body">
          Your message has reached us. A member of the Echo 7 team reads every enquiry
          personally — no automated triage — and we'll come back to you within one
          working day.
        </p>
        <div class="thankyou__links">
          <a href="/" class="btn-primary">Back to homepage →</a>
          <a href="/insights/" class="link-subtle">Browse Insights while you wait</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .thankyou {
    min-height: 50vh;
    display: flex;
    align-items: center;
  }

  .thankyou__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--colour-accent);
    margin-bottom: var(--space-sm);
  }

  .thankyou__headline {
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .thankyou__body {
    margin-top: var(--space-md);
    color: var(--colour-text-muted);
    font-size: 1.05rem;
    max-width: 48ch;
  }

  .thankyou__links {
    margin-top: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
</style>
