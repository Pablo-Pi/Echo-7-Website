---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyEcho7 from '../components/WhyEcho7.astro';
import Credibility from '../components/Credibility.astro';
import PricingPhilosophy from '../components/PricingPhilosophy.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Echo 7 — Technical Sovereignty for UK Mid-Market Business"
  description="Echo 7 quantifies your IT estate's hidden debt in pounds, then rebuilds it as a UK-locked cloud estate you own outright. Fixed fee. You keep the keys."
  canonicalPath="/"
>
  <Nav />
  <main>
    <Hero />
    <Problem />
    <WhatWeDo />
    <HowItWorks />
    <WhyEcho7 />
    <Credibility />
    <PricingPhilosophy />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
