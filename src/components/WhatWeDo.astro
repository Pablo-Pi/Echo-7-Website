---
const cards = [
  {
    id: 'sovereignty-index',
    number: '01',
    title: 'The Sovereignty Index™',
    tagline: 'See your estate the way the board should.',
    body: "A structured diagnostic across five pillars — Identity, Velocity, Resilience, Security, Cognitive — producing one thing no generalist provider will give you: your Technical Debt Burden, stated in pounds, on a single page your board can act on. Fixed fee. No obligation to go further.",
  },
  {
    id: 'sovereign-vault',
    number: '02',
    title: 'Synapse-7™ Sovereign Vault',
    tagline: 'A UK-locked estate you own outright.',
    body: "A Zero-Trust, zero-standing-access cloud estate built in code and deployed to UK regions, with data residency enforced by Azure Policy at the platform level. Not a promise — a policy. On handover you receive the keys and the Continuity Codex: complete documentation of your exit, ready from day one. You can leave at any time. That is contractual.",
  },
  {
    id: 'managed-sovereignty',
    number: '03',
    title: 'Managed Sovereignty',
    tagline: 'Stay sovereign as you grow.',
    body: "A quarterly strategic review measuring all five pillars, tracking movement against your baseline, and reporting to the board in plain language. Advisory, not operational dependency. Your team — or any team you choose — runs the estate. We measure it.",
  },
];
---
<section class="whatwedo section" id="what-we-do">
  <div class="container">
    <h2 class="whatwedo__headline text-column" data-fade>
      Technical Sovereignty. Not a metaphor — an architecture.
    </h2>
    <p class="whatwedo__lead text-column" data-fade style="--fade-delay:80ms">
      Technical Sovereignty means the right to own and control your digital territory:
      your data, your infrastructure, your exit. Echo 7 delivers it in three stages —
      each a separate decision, each a fixed fee, none of them a trap.
    </p>

    <div class="whatwedo__cards">
      {cards.map((card, i) => (
        <div class="whatwedo__card" id={card.id} data-fade style={`--fade-delay:${i * 100}ms`}>
          <span class="whatwedo__card-number gradient-text">{card.number}</span>
          <h3 class="whatwedo__card-title">{card.title}</h3>
          <p class="whatwedo__card-tagline">{card.tagline}</p>
          <p class="whatwedo__card-body">{card.body}</p>
        </div>
      ))}
    </div>

    <div class="whatwedo__cta" data-fade>
      <a href="/contact" class="btn-primary">
        Start with the Index →
      </a>
    </div>
  </div>
</section>

<style>
  .whatwedo__headline {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    max-width: 22ch;
  }

  .whatwedo__lead {
    margin-top: var(--space-md);
    color: var(--colour-text-muted);
    font-size: 1.05rem;
  }

  .whatwedo__cards {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .whatwedo__card {
    position: relative;
    padding: var(--space-lg) var(--space-md);
    border: 1px solid var(--colour-hairline);
    border-radius: var(--radius-md);
    background: linear-gradient(160deg, rgba(232, 230, 240, 0.03), transparent 60%);
    transition: border-color 280ms var(--ease-quiet), transform 280ms var(--ease-quiet), box-shadow 280ms var(--ease-quiet);
  }

  .whatwedo__card:hover {
    border-color: rgba(43, 253, 215, 0.45);
    transform: translateY(-4px);
    box-shadow: 0 24px 48px -24px rgba(43, 253, 215, 0.25);
  }

  .whatwedo__card-number {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
  }

  .whatwedo__card-title {
    margin-top: var(--space-sm);
    font-size: 1.3rem;
    max-width: 22ch;
  }

  .whatwedo__card-tagline {
    margin-top: var(--space-xs);
    color: var(--colour-text);
    font-weight: 600;
    font-size: 1rem;
  }

  .whatwedo__card-body {
    margin-top: var(--space-sm);
    color: var(--colour-text-muted);
    font-size: 0.95rem;
  }

  .whatwedo__cta {
    margin-top: var(--space-xl);
    text-align: center;
  }

  @media (min-width: 880px) {
    .whatwedo__cards {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }
</style>
