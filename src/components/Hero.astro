---
import SynapseField from './SynapseField.astro';
---
<section class="hero" id="hero">
  <div class="hero__motif" aria-hidden="true">
    <svg viewBox="0 0 1200 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <g stroke="#E8E6F0" stroke-width="1" fill="none">
        <line x1="80" y1="100" x2="320" y2="50" />
        <line x1="320" y1="50" x2="600" y2="140" />
        <line x1="600" y1="140" x2="880" y2="70" />
        <line x1="880" y1="70" x2="1140" y2="180" />
        <line x1="80" y1="100" x2="240" y2="300" />
        <line x1="240" y1="300" x2="600" y2="140" />
        <line x1="240" y1="300" x2="480" y2="470" />
        <line x1="600" y1="140" x2="760" y2="400" />
        <line x1="760" y1="400" x2="480" y2="470" />
        <line x1="760" y1="400" x2="1040" y2="450" />
        <line x1="880" y1="70" x2="1040" y2="450" />
        <line x1="480" y1="470" x2="690" y2="610" />
        <line x1="690" y1="610" x2="1040" y2="450" />
      </g>
      <g fill="#75FD98">
        <circle cx="80" cy="100" r="3" />
        <circle cx="320" cy="50" r="3" />
        <circle cx="600" cy="140" r="3" />
        <circle cx="880" cy="70" r="3" />
        <circle cx="1140" cy="180" r="3" />
        <circle cx="240" cy="300" r="3" />
        <circle cx="480" cy="470" r="3" />
        <circle cx="760" cy="400" r="3" />
        <circle cx="1040" cy="450" r="3" />
        <circle cx="690" cy="610" r="3" />
      </g>
    </svg>
  </div>

  <div class="hero__aurora" aria-hidden="true">
    <span class="hero__blob hero__blob--a"></span>
    <span class="hero__blob hero__blob--b"></span>
  </div>

  <SynapseField />

  <div class="container">
    <div class="hero__text">
      <p class="hero__eyebrow" data-fade>Technical Sovereignty for UK mid-market business</p>
      <h1 class="hero__headline" data-fade style="--fade-delay:60ms">
        <span class="hero__line">YOUR <span class="gradient-text">IT</span> ESTATE</span>
        <span class="hero__line">IS RUNNING.</span>
        <span class="hero__line hero__line--accent gradient-text">IS IT YOURS?</span>
      </h1>
      <p class="hero__subhead" data-fade style="--fade-delay:160ms">
        Most UK mid-market businesses are operating on an IT estate they cannot fully see,
        cannot cleanly exit, and do not actually control. Echo 7 moves you off fragile legacy
        infrastructure and onto a secure, UK-resident cloud estate you own outright. Fixed fee.
        Keys handed over. Data that never leaves UK soil — enforced by policy, not promised in copy.
      </p>
      <div class="hero__actions" data-fade style="--fade-delay:280ms">
        <a href="mailto:hello@echo7.io?subject=Measure%20Your%20Technical%20Debt%20Burden" class="btn-primary btn-primary--glow">
          Measure your Technical Debt Burden →
        </a>
        <a href="#the-problem" class="link-subtle">How it works ↓</a>
      </div>
    </div>
  </div>

  <div class="hero__scroll-cue" aria-hidden="true"><span></span></div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: calc(var(--space-xl) + 2rem) var(--space-xl);
    overflow: visible;
    min-height: 78vh;
    display: flex;
    align-items: center;
  }

  /* Background: faint neural network motif */
  .hero__motif {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.08;
    pointer-events: none;
  }

  .hero__motif svg {
    width: 100%;
    height: 100%;
  }

  /* Floating aurora colour blobs */
  .hero__aurora {
    position: absolute;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
  }

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.22;
    mix-blend-mode: screen;
  }

  .hero__blob--a {
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, var(--colour-gradient-start), transparent 70%);
    top: -12%;
    right: 0%;
    animation: aurora-drift-a 32s ease-in-out infinite;
  }

  .hero__blob--b {
    width: 34vw;
    height: 34vw;
    background: radial-gradient(circle, var(--colour-gradient-end), transparent 70%);
    bottom: -14%;
    left: -6%;
    animation: aurora-drift-b 36s ease-in-out infinite;
  }

  @keyframes aurora-drift-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-3%, 4%) scale(1.08); }
  }

  @keyframes aurora-drift-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(4%, -4%) scale(1.06); }
  }

  /* Text content */
  .hero__text {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--colour-accent);
    margin-bottom: var(--space-sm);
  }

  .hero__headline {
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    display: flex;
    flex-direction: column;
    gap: 0.04em;
    line-height: 1.0;
  }

  .hero__line {
    display: block;
  }

  .hero__line--accent {
    display: block;
  }

  .hero__subhead {
    margin-top: var(--space-md);
    max-width: 48ch;
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--colour-text-muted);
  }

  .hero__actions {
    margin-top: var(--space-lg);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
  }

  /* Scroll cue line */
  .hero__scroll-cue {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .hero__scroll-cue span {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--colour-text-muted));
    animation: cue-pulse 2.4s ease-in-out infinite;
  }

  @keyframes cue-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.9; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__blob,
    .hero__scroll-cue span {
      animation: none;
    }
  }
</style>
