---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  canonicalPath: string;
  backLink?: { href: string; label: string };
}

const { title, description, publishDate, canonicalPath, backLink } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${title} — Echo 7 Insights`} description={description} canonicalPath={canonicalPath}>
  <Nav />
  <main>
    <article class="article section">
      <div class="container text-column">
        {backLink && (
          <a href={backLink.href} class="article__back link-subtle">← {backLink.label}</a>
        )}
        <p class="article__date">{formattedDate}</p>
        <h1 class="article__title">{title}</h1>
        <div class="article__body">
          <slot />
        </div>
        <div class="article__footer-nav">
          <a href="/insights/" class="link-subtle">← Back to Insights</a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article__back {
    display: inline-block;
    margin-bottom: var(--space-md);
    font-size: 0.85rem;
  }

  .article__date {
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--colour-text-muted);
  }

  .article__title {
    margin-top: var(--space-sm);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
  }

  .article__body {
    margin-top: var(--space-lg);
    color: var(--colour-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .article__body :global(p) {
    margin-bottom: var(--space-md);
  }

  .article__body :global(p:first-of-type) {
    font-size: 1.18rem;
    color: var(--colour-text);
  }

  .article__body :global(h2) {
    position: relative;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    padding-top: var(--space-md);
    font-size: clamp(1.25rem, 2.6vw, 1.55rem);
    letter-spacing: 0.01em;
    color: var(--colour-accent);
  }

  .article__body :global(h2)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 32px;
    height: 2px;
    background: var(--gradient-primary);
  }

  .article__body :global(strong) {
    color: var(--colour-accent);
    font-weight: 600;
  }

  .article__body :global(a) {
    color: var(--colour-accent);
    text-decoration: underline;
    text-decoration-color: rgba(43, 253, 215, 0.35);
    text-underline-offset: 2px;
    transition: text-decoration-color 200ms var(--ease-quiet);
  }

  .article__body :global(a:hover),
  .article__body :global(a:focus-visible) {
    text-decoration-color: var(--colour-accent);
  }

  .article__footer-nav {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--colour-hairline);
  }
</style>
